---
import "../styles/portfolio.css";

import Hero from "../components/Hero.astro";
import StatsSection from "../components/StatsSection.astro";
import AwardsSection from "../components/AwardsSection.astro";
import NewsSection from "../components/NewsSection.astro";
import EducationSection from "../components/EducationSection.astro";
import AwardLightbox from "../components/AwardLightbox.astro";
import PortfolioScripts from "../components/PortfolioScripts.astro";

import { authorName, scholarAuthorId, profile, stats, awards, newsImages, education } from "../data/siteContent";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{authorName} | Research & Engineering</title>
    <meta
      name="description"
      content="PhD Candidate | 5G/6G Wireless Engineer. Random access, scheduling, PHY/MAC simulation, 3GPP."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=Montserrat:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="page-frame">
      <Hero
        authorName={authorName}
        scholarAuthorId={scholarAuthorId}
        subtitle={profile.subtitle}
        cvUpdated={profile.cvUpdated}
        focusAreas={profile.focusAreas}
        portraitSrc={profile.portraitSquare.src}
        cvHref={profile.cvPdf}
      />

      <StatsSection
        citations={stats.citations}
        hIndex={stats.hIndex}
        i10Index={stats.i10Index}
        updatedAt={stats.updatedAt}
      />

      <AwardsSection
        awardWiopt2024Src={awards.awardWiopt2024.src}
        awardDyspan2024Src={awards.awardDyspan2024.src}
        wioptLink={awards.awardLinks.wiopt}
        dyspanLink={awards.awardLinks.dyspan}
      />

      <NewsSection
        dyspan2025Src={newsImages.dyspan2025.src}
        wioptReceptionSrc={newsImages.wioptReception.src}
        icc2024Src={newsImages.icc2024.src}
        iccCcSrc={newsImages.iccCc.src}
        dyspanAward1Src={newsImages.dyspanAward1.src}
        dyspanAward2Src={newsImages.dyspanAward2.src}
      />

      <EducationSection education={education} />
    </main>

    <AwardLightbox />
    <PortfolioScripts />
  </body>
</html>
